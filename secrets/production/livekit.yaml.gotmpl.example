# Vorlage fuer secrets/livekit.yaml.gotmpl
# Workflow:
#   cp secrets/livekit.yaml.gotmpl.example secrets/livekit.yaml.gotmpl
#   $EDITOR secrets/livekit.yaml.gotmpl
#   sops -e -i secrets/livekit.yaml.gotmpl       # in-place verschluesseln
#
# Pro ocelot-Instanz ein eigenes Key/Secret-Paar.
# Generieren z.B. mit:
#   echo "API$(openssl rand -hex 14):$(openssl rand -hex 32)"
#
# WICHTIG: Keys MUESSEN unter storeKeysInSecret.keys stehen (NICHT unter
# livekit.keys), sonst landen sie in der ConfigMap statt in einem K8s-Secret.
# Das values/livekit.yaml.gotmpl setzt entsprechend storeKeysInSecret.enabled.

storeKeysInSecret:
  keys:
    APIstaging001: REPLACE_WITH_32_BYTE_HEX_SECRET
    # APIstaging002: ...   # weitere Tenants
