# Vorlage fuer secrets/production/monitoring.yaml.gotmpl -- analog zur Stage-
# Vorlage. Eigener Discord-Channel fuer Prod empfohlen.
#
# Workflow:
#   cp secrets/production/monitoring.yaml.gotmpl.example secrets/production/monitoring.yaml.gotmpl
#   $EDITOR secrets/production/monitoring.yaml.gotmpl
#   sops -e -i secrets/production/monitoring.yaml.gotmpl

secrets:
  monitoring:
    discord_webhook_url: https://discord.com/api/webhooks/REPLACE_ME
