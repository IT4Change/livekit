# Vorlage fuer secrets/default/monitoring.yaml.gotmpl -- Discord-Webhook fuer
# Alertmanager.
#
# Workflow:
#   cp secrets/default/monitoring.yaml.gotmpl.example secrets/default/monitoring.yaml.gotmpl
#   $EDITOR secrets/default/monitoring.yaml.gotmpl
#   sops -e -i secrets/default/monitoring.yaml.gotmpl
#
# Discord-Webhook anlegen:
#   Server -> Settings -> Integrations -> Webhooks -> New Webhook
#   -> Channel waehlen, "Copy Webhook URL"
#
# Bot-Anzeigename ("Meet Stage" / "Meet") wird NICHT hier konfiguriert,
# sondern in environments/<env>.yaml.gotmpl unter monitoring.DISCORD_USERNAME.
# Der Wert wird vom Slack-Payload-username-Feld als Bot-Identitaet verwendet.
#
# WICHTIG: URL OHNE /slack-Suffix eintragen -- das Manifest haengt es selbst
# an, weil Discord nur unter <webhook>/slack das Slack-kompatible Payload-
# Format akzeptiert das Alertmanagers slackConfigs-Receiver schickt.
# Beispiel: https://discord.com/api/webhooks/1234567890/abcDEF...

secrets:
  monitoring:
    discord_webhook_url: https://discord.com/api/webhooks/REPLACE_ME
