# Vorlage fuer secrets/default/meet.yaml.gotmpl -- Credentials, mit denen das
# Meet-UI seine LiveKit-Tokens signiert. Wird vom helmfile als env-level
# Secret geladen (siehe environments.default.secrets im helmfile.yaml.gotmpl)
# und ist im Meet-Manifest als .StateValues.secrets.meet.* verfuegbar.
#
# Workflow:
#   cp secrets/default/meet.yaml.gotmpl.example secrets/default/meet.yaml.gotmpl
#   $EDITOR secrets/default/meet.yaml.gotmpl
#   sops -e -i secrets/default/meet.yaml.gotmpl
#
# WICHTIG: Derselbe Key+Secret muss zusaetzlich im
# secrets/default/livekit.yaml.gotmpl unter storeKeysInSecret.keys eingetragen
# werden, sonst weist der LiveKit-Server die vom Meet-UI signierten Tokens
# zurueck.
#
# Konvention:
#   - Eigener Key fuer das Meet-UI -- NICHT denselben wie das ocelot-Backend.
#   - API-Key beginnt mit "API" + sprechendes Suffix (z.B. APImeetstaging).
#   - Secret: 32+ random characters (`openssl rand -base64 32`).

secrets:
  meet:
    LIVEKIT_API_KEY: APImeetstaging
    LIVEKIT_API_SECRET: REPLACE_WITH_32_PLUS_RANDOM_CHARS
