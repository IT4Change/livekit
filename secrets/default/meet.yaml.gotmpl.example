# Vorlage fuer secrets/default/meet.yaml.gotmpl -- enthaelt sowohl die Meet-UI-
# Credentials als auch die freigegebenen Raum-Namen mit optionalem Password.
# Wird vom helmfile als env-level Secret geladen (siehe environments.default.
# secrets im helmfile.yaml.gotmpl); im Manifest als .StateValues.secrets.* lesbar.
#
# Workflow:
#   cp secrets/default/meet.yaml.gotmpl.example secrets/default/meet.yaml.gotmpl
#   $EDITOR secrets/default/meet.yaml.gotmpl
#   sops -e -i secrets/default/meet.yaml.gotmpl
#
# WICHTIG: Der API-Key+Secret aus secrets.meet muss zusaetzlich im
# secrets/default/livekit.yaml.gotmpl unter storeKeysInSecret.keys eingetragen
# werden, sonst weist der LiveKit-Server die Meet-Tokens zurueck.
#
# Raum-Konfiguration (secrets.rooms):
#   - Liste der erlaubten Raeume. Nur diese werden vom Init-Container
#     pre-created und nur auf diese akzeptiert die Meet-API ein Token.
#   - Optional `password`: Passwort fuer den Raum-Beitritt. Plain-Text in
#     sops-encryptetem File ist OK (sops ist die Trust-Boundary). Falls leer
#     oder nicht gesetzt: kein Passwort noetig.
#   - `displayName`: in der Landing-Page angezeigter Name.

secrets:
  meet:
    LIVEKIT_API_KEY: APImeetstaging
    LIVEKIT_API_SECRET: REPLACE_WITH_32_PLUS_RANDOM_CHARS
  rooms:
    - name: it4c
      displayName: IT4C Allgemein
    # Beispiel mit Passwort:
    # - name: standup
    #   displayName: Daily Standup
    #   password: REPLACE_WITH_ROOM_PASSWORD
